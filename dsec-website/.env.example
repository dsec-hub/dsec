# Copy to .env.local and fill in real values. Do not commit secrets.

# --- dsec-api public feed (live projects/events + their images) ---
# Public, no-auth endpoints under /website. Leave blank to fall back to the
# "coming soon" placeholders. No NEXT_PUBLIC_ needed — fetched server-side.
DSEC_API_URL=https://your-dsec-api.vercel.app

# --- On-demand cache revalidation (called by the dashboard) ---
# Shared secret the dashboard sends to POST /api/revalidate to drop a cached
# feed after an edit. Must MATCH dsec-app's REVALIDATE_SECRET. If blank, the
# endpoint rejects all calls and feeds only refresh on the 24h fallback.
REVALIDATE_SECRET=

# OpenAI (used by scripts/ image + content generation)
OPENAI_API_KEY=

# --- Email (Resend) ---
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender address. The domain must be verified in Resend first.
EMAIL_FROM="DSEC <noreply@dsec.club>"
# Inbox that receives sponsorship enquiries.
SPONSOR_INBOX=admin@dsec.club
# Inbox that receives general contact messages.
CONTACT_INBOX=admin@dsec.club

# --- Telegram notifications ---
# Bot token from @BotFather. Leave blank to disable Telegram pings.
TELEGRAM_BOT_TOKEN=
# Target chat/channel/group id (e.g. -1001234567890).
TELEGRAM_CHAT_ID=

# --- Cloudflare Turnstile (bot/captcha) ---
# From https://dash.cloudflare.com/?to=/:account/turnstile
# Leave blank to disable the captcha (honeypot + gibberish checks stay on).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
