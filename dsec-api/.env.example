# DSEC Agent API — environment variables.
# Copy to .env for local dev. In production set these as Vercel project env vars
# (never commit real secrets).

# --- Shared agent / Apps Script auth ---
AGENT_SECRET=change-me-agent-secret

# --- Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Email drafting context ---
CALCOM_LINK=https://cal.com/dsec
SIGNATURE=Best regards,\nThe DSEC Committee
TONE=friendly, concise, and professional

# --- Dashboard / admin / docs basic auth ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-dashboard-pass

# --- Database: Neon Postgres (use the POOLED / pgBouncer connection string) ---
# Example: postgresql+psycopg://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# For local dev you may leave the SQLite default below.
DATABASE_URL=sqlite:///./local.db

# Apply Alembic migrations on startup (handy locally). On Vercel, prefer running
# `alembic upgrade head` as a deploy step and set this to false.
RUN_MIGRATIONS_ON_STARTUP=true

# --- API keys & rate limiting ---
API_KEY_PREFIX=dsec_live_
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_PER_IP_PER_MIN=120
RATE_LIMIT_TRIGGER_PER_DAY=200
GLOBAL_DAILY_LLM_CAP=1000
MAX_REQUEST_BYTES=100000

# --- Supabase Storage (image media for events/projects) ---
# Server-side ONLY. Create a Supabase project, then a PUBLIC bucket named below.
# The service-role key bypasses RLS — never expose it to the browser / dsec-app
# client / dsec-website. Leave blank to disable uploads (POST /media -> 503).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media
MEDIA_MAX_UPLOAD_BYTES=15000000
MEDIA_MAX_DIMENSION=2000
# Document/image attachments (sponsors) — PDFs allowed, auto-compressed.
ATTACHMENT_MAX_UPLOAD_BYTES=25000000

# --- Tally (post-event review forms) ---
# Server-side ONLY (the dsec-app calls this API; it never sees the key).
# Create a key at tally.so → Settings → API. Leave blank to disable the
# "Create review form" action (POST .../review-form -> 503).
TALLY_API_KEY=
TALLY_API_BASE=https://api.tally.so

# --- Vercel Cron auth (daily reconciliation sync) ---
CRON_SECRET=change-me-cron-secret

# --- v2 webhook secrets (reserved) ---
DISCORD_WEBHOOK_SECRET=
CALCOM_WEBHOOK_SECRET=
