# DSEC Member Portal (app.dsec.club) — copy to .env.local and fill in.

# --- Database: same Neon Postgres dsec-api owns (use the POOLED string in prod) ---
DATABASE_URL=

# --- dsec-api backend (same API as the website + hub) ---
# The public `/website/*` feed needs no auth; that's all the portal calls today.
DSEC_API_URL=https://api.dsec.club
# Only needed once the portal calls authenticated endpoints.
DSEC_API_KEY=

# --- Supabase ---
# The portal holds NO Supabase creds; images come through dsec-api /media.

# --- Public website (outbound links) ---
DSEC_WEBSITE_URL=https://dsec.club

# --- Future member auth (generate: `openssl rand -base64 32`) ---
AUTH_SECRET=
