# DSEC Agent API — environment variables.
# Copy to .env for local dev. In production set these as Vercel project env vars
# (never commit real secrets).

# --- Shared agent / Apps Script auth ---
AGENT_SECRET=change-me-agent-secret

# --- Anthropic (Claude Haiku 4.5) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Email drafting context ---
CALCOM_LINK=https://cal.com/dsec
SIGNATURE=Best regards,\nThe DSEC Committee
TONE=friendly, concise, and professional

# --- Dashboard / admin / docs basic auth ---
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-dashboard-pass

# --- Database: Neon Postgres (use the POOLED / pgBouncer connection string) ---
# Example: postgresql+psycopg://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# For local dev you may leave the SQLite default below.
DATABASE_URL=sqlite:///./local.db

# Apply Alembic migrations on startup (handy locally). On Vercel, prefer running
# `alembic upgrade head` as a deploy step and set this to false.
RUN_MIGRATIONS_ON_STARTUP=true

# --- API keys & rate limiting ---
API_KEY_PREFIX=dsec_live_
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_PER_IP_PER_MIN=120
RATE_LIMIT_TRIGGER_PER_DAY=200
GLOBAL_DAILY_LLM_CAP=1000
MAX_REQUEST_BYTES=100000

# --- Member verification cards (portal digital membership card) ---
# Codes are HMAC-derived from the roster id. Blank reuses AGENT_SECRET (no new
# required secret); set to rotate every member's code independently.
MEMBER_CODE_SECRET=
# Public base the card's QR encodes; door staff scan it to verify a member.
MEMBER_VERIFY_BASE_URL=https://localhost:3001/verify
# MEMBER_VERIFY_BASE_URL=https://app.dsec.club/verify


# --- OAuth 2.1 (MCP login-based auth) ---
# Lets MCP clients (e.g. Claude.ai) connect by logging in instead of pasting a
# key. The HMAC that signs the in-flight authorize request reuses AGENT_SECRET.
OAUTH_ENABLED=true
# Pin the public issuer origin in production so it can't be set by a spoofed
# Host header. Leave blank to derive it per-request (correct for local/dev).
# OAUTH_ISSUER=https://api.dsec.club/
OAUTH_ISSUER=https://localhost:3000/
# Token lifetimes (seconds). Defau/lts: access 1h, refresh 60d, auth code 10m.
OAUTH_ACCESS_TOKEN_TTL=3600
OAUTH_REFRESH_TOKEN_TTL=5184000
OAUTH_AUTH_CODE_TTL=600

# --- Supabase Storage (image media for events/projects) ---
# Server-side ONLY. Create a Supabase project, then a PUBLIC bucket named below.
# The service-role key bypasses RLS — never expose it to the browser / dsec-app
# client / dsec-website. Leave blank to disable uploads (POST /media -> 503).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media
MEDIA_MAX_UPLOAD_BYTES=15000000
MEDIA_MAX_DIMENSION=2000
# Document/image attachments (sponsors) — PDFs allowed, auto-compressed.
ATTACHMENT_MAX_UPLOAD_BYTES=25000000

# --- Tally (post-event review forms) ---
# Server-side ONLY (the dsec-app calls this API; it never sees the key).
# Create a key at tally.so → Settings → API. Leave blank to disable the
# "Create review form" action (POST .../review-form -> 503).
TALLY_API_KEY=
TALLY_API_BASE=https://api.tally.so

# --- Vercel Cron auth (daily reconciliation sync) ---
CRON_SECRET=change-me-cron-secret

# --- Task-assignment notifications handed off to dsec-hub ---
# dsec-api has no email/Telegram/Discord of its own; the dashboard (dsec-hub)
# owns all delivery. When a task is (re)assigned via the REST API or MCP, we POST
# a best-effort event to hub's internal endpoint so the assignee still gets
# pinged. Set HUB_NOTIFY_URL to hub's internal route and HUB_NOTIFY_SECRET to a
# strong random value (`openssl rand -hex 32`) that MATCHES HUB_NOTIFY_SECRET in
# the dsec-hub project. Leave blank to disable the hand-off (local dev).
HUB_NOTIFY_URL=
HUB_NOTIFY_SECRET=

# --- v2 webhook secrets (reserved) ---
DISCORD_WEBHOOK_SECRET=
CALCOM_WEBHOOK_SECRET=

# --- CORS: browser origins allowed to call the API directly ---
# Only matters for fetches issued from a browser tab on one of our own
# subdomains; server-to-server calls from the Next.js apps aren't subject to it.
# Comma-separated. The default below already covers prod + local dev, so you
# usually don't need to set this. Override only to add/remove an origin.
# CORS_ALLOW_ORIGINS=https://dsec.club,https://www.dsec.club,https://app.dsec.club,https://hub.dsec.club,http://localhost:3000,http://localhost:3001,http://localhost:3002
