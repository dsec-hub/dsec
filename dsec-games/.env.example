# --- dsec-api (server-only; the key must NEVER reach the browser) ---
DSEC_API_URL=http://localhost:8000
# The scoped games-site service key (read + write). Mint with:
#   .venv/bin/python -m scripts.create_api_key --label "games-site" --scopes read,write
DSEC_API_KEY=

# --- Shared portal session (Auth.js) ---
# MUST equal dsec-app's AUTH_SECRET so this app can decode the shared session
# cookie and read the logged-in player's account id + email.
AUTH_SECRET=
AUTH_TRUST_HOST=true
# Set on BOTH dsec-app and dsec-games to share the session cookie across
# subdomains. Leave blank locally (host-only cookie); set to .dsec.club in prod.
AUTH_COOKIE_DOMAIN=
# Where to send unauthenticated players to sign in (the member portal).
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
# This app's own public origin. Sent to the portal as the post-login callbackUrl
# so it can bounce a player straight back here after they verify their code.
# Prod: https://games.dsec.club (the default when unset). Dev: this app's URL.
NEXT_PUBLIC_GAMES_URL=http://localhost:3003
# Public DSEC website (footer / outbound links).
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# --- Local dev convenience (non-production only) ---
# When there is no portal session in dev, play as this account so the games are
# fully testable standalone. Ignored in production.
GAMES_DEV_ACCOUNT_ID=
GAMES_DEV_EMAIL=
