# dsec-app environment — copy to .env.local and fill in. Never commit secrets.

# --- Database: Neon Postgres (same DB dsec-api owns; use the POOLED string) ---
# postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=

# --- NextAuth session signing key (generate: `openssl rand -base64 32`) ---
AUTH_SECRET=

# --- dsec-api backend (server-side calls: AI meeting notes + image uploads) ---
# DSEC_API_KEY must have BOTH the `trigger` scope (AI notes) and the `write`
# scope (image upload/delete via /media). Leave blank to disable those features.
DSEC_API_URL=https://your-dsec-api.vercel.app
DSEC_API_KEY=dsec_live_xxx

# --- Public website on-demand cache revalidation ---
# After a content edit the dashboard pings the public site to drop its cached
# feed, so changes show up without waiting for its 24h fallback. DSEC_WEBSITE_URL
# is the site's origin; REVALIDATE_SECRET must MATCH the website's value. Leave
# either blank to skip the ping (the site still self-heals within 24h).
DSEC_WEBSITE_URL=https://dsec.club
REVALIDATE_SECRET=

# --- Email (member invites via Resend; optional — logs link if unset) ---
# EMAIL_FROM must be on a domain you've VERIFIED in Resend (resend.com/domains),
# e.g. "DSEC Dashboard <noreply@dsec.club>". Without it, sends fall back to the
# shared onboarding@resend.dev sender, which Resend only allows to your own
# account email — any other recipient returns 403. Verify the domain in prod.
RESEND_API_KEY=
EMAIL_FROM=DSEC Dashboard <noreply@dsec.club>
APP_URL=http://localhost:3000

# --- Rate limiting: Upstash Redis (REST) ---
# Powers the per-IP throttle (proxy.ts) and the login brute-force guard
# (auth.ts). Create a free DB at console.upstash.com → copy the REST creds.
# If BOTH are blank, rate limiting fails OPEN (no throttling) — fine for local
# dev, but set them in production. See SECURITY.md.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
