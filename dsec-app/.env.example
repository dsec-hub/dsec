# DSEC Member Portal (app.dsec.club) — copy to .env.local and fill in.

# --- Database: same Neon Postgres dsec-api owns (use the POOLED string in prod) ---
DATABASE_URL=

# --- dsec-api backend (same API as the website + hub) ---
# The public `/website/*` feed + `/members/verify/*` need no auth.
DSEC_API_URL=https://api.dsec.club
# Needed for the membership card + onboarding photo upload. Mint a key with
# BOTH `read` (fetch a member's verification code/QR) and `write` (upload the
# face photo via /media) scopes. Server-only — never exposed to the browser.
DSEC_API_KEY=

# --- Supabase ---
# The portal holds NO Supabase creds; images come through dsec-api /media.

# --- Public website (outbound links) ---
# Server-side feeds / revalidation:
DSEC_WEBSITE_URL=https://dsec.club
# Client-visible URL used by the navbar/footer DSEC links. Point at a locally
# running website during dev, e.g. http://localhost:3000.
NEXT_PUBLIC_WEBSITE_URL=https://dsec.club

# --- Member auth: email one-time code (NextAuth v5, Credentials) ---
# Required. Generate: `openssl rand -base64 32`. Also used to HMAC the login codes.
AUTH_SECRET=
# Public origin of the portal. Prod: https://app.dsec.club
AUTH_URL=http://localhost:3001
# On Vercel/behind a proxy NextAuth needs to trust the host header:
# AUTH_TRUST_HOST=true

# --- Email delivery (Resend) — REQUIRED in production to send login codes ---
# In local dev WITHOUT a key, the 6-digit code is printed to the server console.
RESEND_API_KEY=
# From address for portal emails (login codes + assistance alerts). The domain
# must be verified in Resend.
PORTAL_FROM_EMAIL=DSEC Portal <portal@dsec.club>
# Where member assistance requests are emailed.
DEVS_ALERT_EMAIL=admin@dsec.club
# Committee dashboard origin, used in the assistance alert's "review" link.
HUB_URL=https://hub.dsec.club
